<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <ReportSections>
    <ReportSection>
      <Body>
        <Height>11in</Height>
        <ReportItems>
          <Textbox Name="SchoolNameTxt">
            <CanGrow>true</CanGrow>
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!SchoolName.Value</Value><Style><FontSize>16pt</FontSize><FontWeight>Bold</FontWeight><Color>#1e3a8a</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
            <Top>0.2in</Top><Left>0.5in</Left><Height>0.35in</Height><Width>7.5in</Width>
          </Textbox>
          <Textbox Name="SchoolAddressTxt">
            <CanGrow>true</CanGrow>
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!SchoolAddress.Value</Value><Style><FontSize>9pt</FontSize><Color>#64748b</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
            <Top>0.58in</Top><Left>0.5in</Left><Height>0.22in</Height><Width>7.5in</Width>
          </Textbox>
          <Textbox Name="ReportTitleTxt">
            <CanGrow>true</CanGrow>
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>ADMISSION APPLICATIONS REGISTER</Value><Style><FontSize>13pt</FontSize><FontWeight>Bold</FontWeight><Color>#0f172a</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
            <Top>0.85in</Top><Left>0.5in</Left><Height>0.28in</Height><Width>7.5in</Width>
            <Style><BackgroundColor>#e0f2fe</BackgroundColor><Border><Style>Solid</Style><Color>#7dd3fc</Color></Border></Style>
          </Textbox>
          <Tablix Name="AdmissionTable">
            <TablixBody>
              <TablixColumns>
                <TablixColumn><Width>0.35in</Width></TablixColumn>
                <TablixColumn><Width>1.5in</Width></TablixColumn>
                <TablixColumn><Width>0.9in</Width></TablixColumn>
                <TablixColumn><Width>1.0in</Width></TablixColumn>
                <TablixColumn><Width>1.2in</Width></TablixColumn>
                <TablixColumn><Width>1.0in</Width></TablixColumn>
                <TablixColumn><Width>0.9in</Width></TablixColumn>
                <TablixColumn><Width>0.8in</Width></TablixColumn>
              </TablixColumns>
              <TablixRows>
                <TablixRow>
                  <Height>0.28in</Height>
                  <TablixCells>
                    <TablixCell><CellContents><Textbox Name="H1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>#</Value><Style><FontWeight>Bold</FontWeight><FontSize>8pt</FontSize><Color>#ffffff</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><BackgroundColor>#1e3a8a</BackgroundColor><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="H2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Applicant Name</Value><Style><FontWeight>Bold</FontWeight><FontSize>8pt</FontSize><Color>#ffffff</Color></Style></TextRun></TextRuns><Style><PaddingLeft>4pt</PaddingLeft></Style></Paragraph></Paragraphs><Style><BackgroundColor>#1e3a8a</BackgroundColor><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="H3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>App No</Value><Style><FontWeight>Bold</FontWeight><FontSize>8pt</FontSize><Color>#ffffff</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><BackgroundColor>#1e3a8a</BackgroundColor><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="H4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Class Applied</Value><Style><FontWeight>Bold</FontWeight><FontSize>8pt</FontSize><Color>#ffffff</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><BackgroundColor>#1e3a8a</BackgroundColor><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="H5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Parent/Guardian</Value><Style><FontWeight>Bold</FontWeight><FontSize>8pt</FontSize><Color>#ffffff</Color></Style></TextRun></TextRuns><Style><PaddingLeft>4pt</PaddingLeft></Style></Paragraph></Paragraphs><Style><BackgroundColor>#1e3a8a</BackgroundColor><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="H6"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Applied Date</Value><Style><FontWeight>Bold</FontWeight><FontSize>8pt</FontSize><Color>#ffffff</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><BackgroundColor>#1e3a8a</BackgroundColor><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="H7"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Contact</Value><Style><FontWeight>Bold</FontWeight><FontSize>8pt</FontSize><Color>#ffffff</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><BackgroundColor>#1e3a8a</BackgroundColor><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="H8"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Status</Value><Style><FontWeight>Bold</FontWeight><FontSize>8pt</FontSize><Color>#ffffff</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><BackgroundColor>#1e3a8a</BackgroundColor><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                  </TablixCells>
                </TablixRow>
                <TablixRow>
                  <Height>0.24in</Height>
                  <TablixCells>
                    <TablixCell><CellContents><Textbox Name="D1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=RowNumber(Nothing)</Value><Style><FontSize>8pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style><Color>#e2e8f0</Color></Border><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="D2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!StudentFullName.Value</Value><Style><FontSize>8pt</FontSize></Style></TextRun></TextRuns><Style><PaddingLeft>4pt</PaddingLeft></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style><Color>#e2e8f0</Color></Border><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="D3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!ApplicationNumber.Value</Value><Style><FontSize>8pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style><Color>#e2e8f0</Color></Border><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="D4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!AppliedClass.Value</Value><Style><FontSize>8pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style><Color>#e2e8f0</Color></Border><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="D5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!ParentName.Value</Value><Style><FontSize>8pt</FontSize></Style></TextRun></TextRuns><Style><PaddingLeft>4pt</PaddingLeft></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style><Color>#e2e8f0</Color></Border><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="D6"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(Fields!ApplicationDate.Value,"dd-MMM-yyyy")</Value><Style><FontSize>8pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style><Color>#e2e8f0</Color></Border><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="D7"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!ContactNumber.Value</Value><Style><FontSize>8pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style><Color>#e2e8f0</Color></Border><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="D8"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!Status.Value</Value><Style><FontSize>8pt</FontSize><Color>=IIF(Fields!Status.Value="Approved","#16a34a",IIF(Fields!Status.Value="Rejected","#dc2626","#d97706"))</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Style>Solid</Style><Color>#e2e8f0</Color></Border><VerticalAlign>Middle</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                  </TablixCells>
                </TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixRowHierarchy>
              <TablixMembers>
                <TablixMember><KeepWithGroup>After</KeepWithGroup></TablixMember>
                <TablixMember><Group Name="AdmissionDetail"></Group></TablixMember>
              </TablixMembers>
            </TablixRowHierarchy>
            <TablixColumnHierarchy>
              <TablixMembers>
                <TablixMember/><TablixMember/><TablixMember/><TablixMember/><TablixMember/><TablixMember/><TablixMember/><TablixMember/>
              </TablixMembers>
            </TablixColumnHierarchy>
            <DataSetName>AdmissionDataSet</DataSetName>
            <Top>1.45in</Top><Left>0.5in</Left><Width>8in</Width>
          </Tablix>
          <Textbox Name="FooterNote">
            <CanGrow>true</CanGrow>
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Printed from SchoolSaaS ERP — Admission Management System. For official use only.</Value><Style><FontSize>8pt</FontSize><Color>#94a3b8</Color><FontStyle>Italic</FontStyle></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
            <Top>10.5in</Top><Left>0.5in</Left><Height>0.22in</Height><Width>7.5in</Width>
          </Textbox>
        </ReportItems>
      </Body>
      <Width>8.5in</Width>
      <Page><PageHeight>11in</PageHeight><PageWidth>8.5in</PageWidth><LeftMargin>0.25in</LeftMargin><RightMargin>0.25in</RightMargin><TopMargin>0.25in</TopMargin><BottomMargin>0.25in</BottomMargin></Page>
    </ReportSection>
  </ReportSections>
  <DataSets>
    <DataSet Name="AdmissionDataSet">
      <Fields>
        <Field Name="StudentFullName"><DataField>StudentFullName</DataField></Field>
        <Field Name="ApplicationNumber"><DataField>ApplicationNumber</DataField></Field>
        <Field Name="AppliedClass"><DataField>AppliedClass</DataField></Field>
        <Field Name="ParentName"><DataField>ParentName</DataField></Field>
        <Field Name="ApplicationDate"><DataField>ApplicationDate</DataField></Field>
        <Field Name="ContactNumber"><DataField>ContactNumber</DataField></Field>
        <Field Name="Status"><DataField>Status</DataField></Field>
      </Fields>
      <Query><DataSourceName>DataSource1</DataSourceName><CommandText></CommandText></Query>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="SchoolName"><DataType>String</DataType><DefaultValue><Values><Value>SchoolSaaS Academy</Value></Values></DefaultValue></ReportParameter>
    <ReportParameter Name="SchoolAddress"><DataType>String</DataType><DefaultValue><Values><Value>City Campus</Value></Values></DefaultValue></ReportParameter>
    <ReportParameter Name="ReportGeneratedDate"><DataType>String</DataType><DefaultValue><Values><Value>Today</Value></Values></DefaultValue></ReportParameter>
    <ReportParameter Name="ReportGeneratedBy"><DataType>String</DataType><DefaultValue><Values><Value>System</Value></Values></DefaultValue></ReportParameter>
  </ReportParameters>
  <rd:ReportUnitType>Inch</rd:ReportUnitType>
</Report>
