<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <ReportSections>
    <ReportSection>
      <Body>
        <Height>11in</Height>
        <ReportItems>
          <Textbox Name="TitleTxt">
            <Paragraphs>
              <Paragraph>
                <TextRuns><TextRun><Value>=Parameters!ReportTitle.Value</Value><Style><FontSize>18pt</FontSize><FontWeight>Bold</FontWeight><Color>#0D9488</Color></Style></TextRun></TextRuns>
              </Paragraph>
            </Paragraphs>
            <Top>0.5in</Top><Left>0.5in</Left><Height>0.4in</Height><Width>7.5in</Width>
          </Textbox>

          <Textbox Name="TotalAppTxt">
            <Paragraphs>
              <Paragraph>
                <TextRuns><TextRun><Value>Total Applications: </Value><Style><FontWeight>Bold</FontWeight></Style></TextRun><TextRun><Value>=Parameters!TotalApplications.Value</Value></TextRun></TextRuns>
              </Paragraph>
            </Paragraphs>
            <Top>1.0in</Top><Left>0.5in</Left><Height>0.3in</Height><Width>3.0in</Width>
          </Textbox>

          <Textbox Name="GridHeader1">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Applicant Name</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>1.5in</Top><Left>0.5in</Left><Height>0.3in</Height><Width>2.5in</Width>
            <Style><BackgroundColor>#CCFBF1</BackgroundColor></Style>
          </Textbox>
          <Textbox Name="GridHeader2">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Applied State</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>1.5in</Top><Left>3.1in</Left><Height>0.3in</Height><Width>2.0in</Width>
            <Style><BackgroundColor>#CCFBF1</BackgroundColor></Style>
          </Textbox>
          <Textbox Name="GridHeader3">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Current Status</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>1.5in</Top><Left>5.2in</Left><Height>0.3in</Height><Width>1.8in</Width>
            <Style><BackgroundColor>#CCFBF1</BackgroundColor></Style>
          </Textbox>

          <!-- Standard label informing reports datasets are configured -->
          <Textbox Name="LogNotice">
            <Paragraphs>
              <Paragraph>
                <TextRuns><TextRun><Value>Data bind count successfully linked to pipeline data source.</Value><Style><FontSize>9pt</FontSize><FontStyle>Italic</FontStyle></Style></TextRun></TextRuns>
              </Paragraph>
            </Paragraphs>
            <Top>2.0in</Top><Left>0.5in</Left><Height>0.3in</Height><Width>6.5in</Width>
          </Textbox>
        </ReportItems>
        <Style />
      </Body>
      <Width>8.5in</Width>
      <Page>
        <PageHeight>11in</PageHeight>
        <PageWidth>8.5in</PageWidth>
        <Style />
      </Page>
    </ReportSection>
  </ReportSections>
  <ReportParameters>
    <ReportParameter Name="ReportTitle"><DataType>String</DataType></ReportParameter>
    <ReportParameter Name="TotalApplications"><DataType>String</DataType></ReportParameter>
  </ReportParameters>
  <rd:ReportUnitType>Inch</rd:ReportUnitType>
</Report>
