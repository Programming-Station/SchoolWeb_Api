<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <ReportSections>
    <ReportSection>
      <Body>
        <Height>11in</Height>
        <ReportItems>
          <Textbox Name="TitleTxt">
            <Paragraphs>
              <Paragraph>
                <TextRuns><TextRun><Value>=Parameters!ReportTitle.Value</Value><Style><FontSize>18pt</FontSize><FontWeight>Bold</FontWeight><Color>#E11D48</Color></Style></TextRun></TextRuns>
              </Paragraph>
            </Paragraphs>
            <Top>0.5in</Top><Left>0.5in</Left><Height>0.4in</Height><Width>7.5in</Width>
          </Textbox>

          <Textbox Name="GridHeader1">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Student Name</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>1.2in</Top><Left>0.5in</Left><Height>0.3in</Height><Width>2.5in</Width>
            <Style><BackgroundColor>#FFE4E6</BackgroundColor></Style>
          </Textbox>
          <Textbox Name="GridHeader2">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Father's Name</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>1.2in</Top><Left>3.1in</Left><Height>0.3in</Height><Width>2.5in</Width>
            <Style><BackgroundColor>#FFE4E6</BackgroundColor></Style>
          </Textbox>
          <Textbox Name="GridHeader3">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Mobile Phone</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>1.2in</Top><Left>5.7in</Left><Height>0.3in</Height><Width>2.3in</Width>
            <Style><BackgroundColor>#FFE4E6</BackgroundColor></Style>
          </Textbox>

          <Textbox Name="LogNotice">
            <Paragraphs>
              <Paragraph>
                <TextRuns><TextRun><Value>PTA emergency alerts contact directories bound to EmergencyDataSet.</Value><Style><FontSize>9pt</FontSize><FontStyle>Italic</FontStyle></Style></TextRun></TextRuns>
              </Paragraph>
            </Paragraphs>
            <Top>1.7in</Top><Left>0.5in</Left><Height>0.3in</Height><Width>6.5in</Width>
          </Textbox>
        </ReportItems>
        <Style />
      </Body>
      <Width>8.5in</Width>
      <Page>
        <PageHeight>11in</PageHeight>
        <PageWidth>8.5in</PageWidth>
        <Style />
      </Page>
    </ReportSection>
  </ReportSections>
  <ReportParameters>
    <ReportParameter Name="ReportTitle"><DataType>String</DataType></ReportParameter>
  </ReportParameters>
  <rd:ReportUnitType>Inch</rd:ReportUnitType>
</Report>
