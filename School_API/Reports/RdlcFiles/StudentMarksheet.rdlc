<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <ReportParameters>
    <ReportParameter Name="SchoolName"><DataType>String</DataType><DefaultValue><Values><Value>SchoolSaaS ERP</Value></Values></DefaultValue><Prompt>School Name</Prompt></ReportParameter>
    <ReportParameter Name="SchoolAddress"><DataType>String</DataType><Prompt>Address</Prompt></ReportParameter>
    <ReportParameter Name="Phone"><DataType>String</DataType><Prompt>Phone</Prompt></ReportParameter>
    <ReportParameter Name="Logo"><DataType>String</DataType><Prompt>Logo Base64</Prompt></ReportParameter>
    <ReportParameter Name="PrincipalName"><DataType>String</DataType><Prompt>Principal</Prompt></ReportParameter>
    <ReportParameter Name="PrincipalSignature"><DataType>String</DataType><Prompt>Principal Signature</Prompt></ReportParameter>
    <ReportParameter Name="OfficialSeal"><DataType>String</DataType><Prompt>Official Seal</Prompt></ReportParameter>
    <ReportParameter Name="Watermark"><DataType>String</DataType><Prompt>Watermark</Prompt></ReportParameter>
    <ReportParameter Name="ThemeColor"><DataType>String</DataType><DefaultValue><Values><Value>#1e3a8a</Value></Values></DefaultValue><Prompt>Theme Color</Prompt></ReportParameter>
    <ReportParameter Name="GeneratedDate"><DataType>String</DataType><Prompt>Generated Date</Prompt></ReportParameter>
    <ReportParameter Name="AcademicSession"><DataType>String</DataType><Prompt>Academic Session</Prompt></ReportParameter>
  </ReportParameters>
  <DataSources>
    <DataSource Name="ReportCardDS">
      <ConnectionProperties><DataProvider>System.Data.DataSet</DataProvider><ConnectString /></ConnectionProperties>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ReportCardDataSet">
      <Query>
        <DataSourceName>ReportCardDS</DataSourceName>
        <CommandText />
      </Query>
      <Fields>
        <Field Name="StudentName"><DataField>StudentName</DataField></Field>
        <Field Name="AdmissionNo"><DataField>AdmissionNo</DataField></Field>
        <Field Name="ClassName"><DataField>ClassName</DataField></Field>
        <Field Name="SubjectName"><DataField>SubjectName</DataField></Field>
        <Field Name="MaxMarks"><DataField>MaxMarks</DataField></Field>
        <Field Name="ObtainedMarks"><DataField>ObtainedMarks</DataField></Field>
        <Field Name="Grade"><DataField>Grade</DataField></Field>
        <Field Name="Remarks"><DataField>Remarks</DataField></Field>
        <Field Name="ExamName"><DataField>ExamName</DataField></Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportSections>
    <ReportSection>
      <Body>
        <Height>9in</Height>
        <ReportItems>
          <!-- Header -->
          <Rectangle Name="HeaderRect">
            <ReportItems>
              <Image Name="LogoImg">
                <Source>External</Source>
                <Value>=Parameters!Logo.Value</Value>
                <Sizing>FitProportional</Sizing>
                <Top>0in</Top><Left>0in</Left><Height>0.8in</Height><Width>1in</Width>
              </Image>
              <Textbox Name="SchoolNameTxt">
                <CanGrow>true</CanGrow>
                <Paragraphs><Paragraph><TextRuns><TextRun>
                  <Value>=Parameters!SchoolName.Value</Value>
                  <Style><FontSize>18pt</FontSize><FontWeight>Bold</FontWeight><Color>=Parameters!ThemeColor.Value</Color></Style>
                </TextRun></TextRuns></Paragraph></Paragraphs>
                <Top>0in</Top><Left>1.2in</Left><Height>0.4in</Height><Width>6in</Width>
              </Textbox>
              <Textbox Name="AddressTxt">
                <Paragraphs><Paragraph><TextRuns><TextRun>
                  <Value>=Parameters!SchoolAddress.Value</Value>
                  <Style><FontSize>9pt</FontSize><Color>#555555</Color></Style>
                </TextRun></TextRuns></Paragraph></Paragraphs>
                <Top>0.4in</Top><Left>1.2in</Left><Height>0.25in</Height><Width>6in</Width>
              </Textbox>
              <Textbox Name="ReportTitleTxt">
                <Paragraphs><Paragraph><TextRuns><TextRun>
                  <Value>STUDENT MARKSHEET</Value>
                  <Style><FontSize>14pt</FontSize><FontWeight>Bold</FontWeight><Color>#ffffff</Color></Style>
                </TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
                <Style><BackgroundColor>=Parameters!ThemeColor.Value</BackgroundColor><TextAlign>Center</TextAlign></Style>
                <Top>0.85in</Top><Left>0in</Left><Height>0.3in</Height><Width>7.5in</Width>
              </Textbox>
              <Textbox Name="SessionTxt">
                <Paragraphs><Paragraph><TextRuns><TextRun>
                  <Value>="Academic Session: " &amp; Parameters!AcademicSession.Value</Value>
                  <Style><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight></Style>
                </TextRun></TextRuns></Paragraph></Paragraphs>
                <Top>1.2in</Top><Left>0in</Left><Height>0.2in</Height><Width>3.75in</Width>
              </Textbox>
            </ReportItems>
            <Top>0in</Top><Left>0in</Left><Height>1.5in</Height><Width>7.5in</Width>
          </Rectangle>

          <!-- Data Table -->
          <Tablix Name="MarksTable">
            <TablixBody>
              <TablixColumns>
                <TablixColumn><Width>0.5in</Width></TablixColumn>
                <TablixColumn><Width>2.5in</Width></TablixColumn>
                <TablixColumn><Width>1in</Width></TablixColumn>
                <TablixColumn><Width>1.2in</Width></TablixColumn>
                <TablixColumn><Width>0.8in</Width></TablixColumn>
                <TablixColumn><Width>1.5in</Width></TablixColumn>
              </TablixColumns>
              <TablixRows>
                <TablixRow>
                  <Height>0.25in</Height>
                  <TablixCells>
                    <TablixCell><CellContents><Textbox Name="H1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>S.No.</Value><Style><FontWeight>Bold</FontWeight><Color>#ffffff</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>=Parameters!ThemeColor.Value</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="H2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Subject</Value><Style><FontWeight>Bold</FontWeight><Color>#ffffff</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>=Parameters!ThemeColor.Value</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="H3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Max Marks</Value><Style><FontWeight>Bold</FontWeight><Color>#ffffff</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>=Parameters!ThemeColor.Value</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="H4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Obtained</Value><Style><FontWeight>Bold</FontWeight><Color>#ffffff</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>=Parameters!ThemeColor.Value</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="H5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Grade</Value><Style><FontWeight>Bold</FontWeight><Color>#ffffff</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>=Parameters!ThemeColor.Value</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="H6"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Remarks</Value><Style><FontWeight>Bold</FontWeight><Color>#ffffff</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>=Parameters!ThemeColor.Value</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                  </TablixCells>
                </TablixRow>
                <TablixRow>
                  <Height>0.25in</Height>
                  <TablixCells>
                    <TablixCell><CellContents><Textbox Name="D1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=RowNumber("ReportCardDataSet")</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="D2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!SubjectName.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="D3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!MaxMarks.Value</Value></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="D4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!ObtainedMarks.Value</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="D5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!Grade.Value</Value><Style><FontWeight>Bold</FontWeight><Color>=Parameters!ThemeColor.Value</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="D6"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!Remarks.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                  </TablixCells>
                </TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixColumnHierarchy><TablixMembers><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /></TablixMembers></TablixColumnHierarchy>
            <TablixRowHierarchy>
              <TablixMembers>
                <TablixMember><TablixHeader><Size>0in</Size></TablixHeader></TablixMember>
                <TablixMember><Group Name="ReportCardDataSet_Group"><GroupExpressions><GroupExpression>=Fields!StudentName.Value</GroupExpression></GroupExpressions></Group></TablixMember>
              </TablixMembers>
            </TablixRowHierarchy>
            <DataSetName>ReportCardDataSet</DataSetName>
            <Top>1.6in</Top><Left>0in</Left><Width>7.5in</Width>
          </Tablix>

          <!-- Signature Section -->
          <Textbox Name="SigLine">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Principal's Signature</Value><Style><FontSize>9pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs>
            <Top>8.3in</Top><Left>5in</Left><Height>0.25in</Width>2.5in</Width>
          </Textbox>
          <Textbox Name="GeneratedByTxt">
            <Paragraphs><Paragraph><TextRuns><TextRun>
              <Value>="Generated: " &amp; Parameters!GeneratedDate.Value</Value>
              <Style><FontSize>7pt</FontSize><Color>#999999</Color></Style>
            </TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>8.7in</Top><Left>0in</Left><Height>0.2in</Height><Width>4in</Width>
          </Textbox>
        </ReportItems>
      </Body>
      <Width>7.5in</Width>
      <Page>
        <PageHeight>11in</PageHeight>
        <PageWidth>8.5in</PageWidth>
        <LeftMargin>0.5in</LeftMargin>
        <RightMargin>0.5in</RightMargin>
        <TopMargin>0.5in</TopMargin>
        <BottomMargin>0.5in</BottomMargin>
      </Page>
    </ReportSection>
  </ReportSections>
  <rd:ReportUnitType>Inch</rd:ReportUnitType>
</Report>
