<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <ReportSections>
    <ReportSection>
      <Body>
        <Height>11in</Height>
        <ReportItems>
          <!-- Title -->
          <Textbox Name="TitleTxt">
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>ADMISSION APPLICATION SUMMARY</Value>
                    <Style><FontSize>18pt</FontSize><FontWeight>Bold</FontWeight><Color>#1E3A8A</Color></Style>
                  </TextRun>
                </TextRuns>
                <Style><TextAlign>Center</TextAlign></Style>
              </Paragraph>
            </Paragraphs>
            <Top>0.5in</Top><Left>0.5in</Left><Height>0.4in</Height><Width>7.5in</Width>
          </Textbox>

          <!-- Bio Grid Data -->
          <Textbox Name="LblAppNo">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Application No:</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>1.2in</Top><Left>1.0in</Left><Height>0.25in</Height><Width>1.8in</Width>
          </Textbox>
          <Textbox Name="ValAppNo">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!ApplicationNo.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>1.2in</Top><Left>2.9in</Left><Height>0.25in</Height><Width>4.1in</Width>
          </Textbox>

          <Textbox Name="LblName">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Applicant Name:</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>1.5in</Top><Left>1.0in</Left><Height>0.25in</Height><Width>1.8in</Width>
          </Textbox>
          <Textbox Name="ValName">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!FullName.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>1.5in</Top><Left>2.9in</Left><Height>0.25in</Height><Width>4.1in</Width>
          </Textbox>

          <Textbox Name="LblDOB">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Date of Birth:</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>1.8in</Top><Left>1.0in</Left><Height>0.25in</Height><Width>1.8in</Width>
          </Textbox>
          <Textbox Name="ValDOB">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!DateOfBirth.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>1.8in</Top><Left>2.9in</Left><Height>0.25in</Height><Width>4.1in</Width>
          </Textbox>

          <Textbox Name="LblCourse">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Applied Course:</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>2.1in</Top><Left>1.0in</Left><Height>0.25in</Height><Width>1.8in</Width>
          </Textbox>
          <Textbox Name="ValCourse">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!AppliedCourse.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>2.1in</Top><Left>2.9in</Left><Height>0.25in</Height><Width>4.1in</Width>
          </Textbox>

          <Textbox Name="LblStatus">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Processing Status:</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>2.4in</Top><Left>1.0in</Left><Height>0.25in</Height><Width>1.8in</Width>
          </Textbox>
          <Textbox Name="ValStatus">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!Status.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>2.4in</Top><Left>2.9in</Left><Height>0.25in</Height><Width>4.1in</Width>
          </Textbox>

          <Textbox Name="LblFather">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Father's Name:</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>2.7in</Top><Left>1.0in</Left><Height>0.25in</Height><Width>1.8in</Width>
          </Textbox>
          <Textbox Name="ValFather">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!FathersName.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>2.7in</Top><Left>2.9in</Left><Height>0.25in</Height><Width>4.1in</Width>
          </Textbox>

          <Textbox Name="LblMother">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Mother's Name:</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>3.0in</Top><Left>1.0in</Left><Height>0.25in</Height><Width>1.8in</Width>
          </Textbox>
          <Textbox Name="ValMother">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!MothersName.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>3.0in</Top><Left>2.9in</Left><Height>0.25in</Height><Width>4.1in</Width>
          </Textbox>

          <Textbox Name="LblContact">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Contact Number:</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>3.3in</Top><Left>1.0in</Left><Height>0.25in</Height><Width>1.8in</Width>
          </Textbox>
          <Textbox Name="ValContact">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!ContactNo.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>3.3in</Top><Left>2.9in</Left><Height>0.25in</Height><Width>4.1in</Width>
          </Textbox>

          <Textbox Name="LblEmail">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Email Address:</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>3.6in</Top><Left>1.0in</Left><Height>0.25in</Height><Width>1.8in</Width>
          </Textbox>
          <Textbox Name="ValEmail">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Parameters!EmailAddress.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>3.6in</Top><Left>2.9in</Left><Height>0.25in</Height><Width>4.1in</Width>
          </Textbox>

          <!-- Footer tag -->
          <Textbox Name="FooterInfo">
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>School SAAS System • Admissions Office Copy</Value><Style><FontSize>8pt</FontSize><FontStyle>Italic</FontStyle></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Top>4.5in</Top><Left>1.0in</Left><Height>0.25in</Height><Width>6.0in</Width>
            <Style><TextAlign>Center</TextAlign></Style>
          </Textbox>
        </ReportItems>
        <Style />
      </Body>
      <Width>8.5in</Width>
      <Page>
        <PageHeight>11in</PageHeight>
        <PageWidth>8.5in</PageWidth>
        <Style />
      </Page>
    </ReportSection>
  </ReportSections>
  <ReportParameters>
    <ReportParameter Name="ApplicationNo"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank></ReportParameter>
    <ReportParameter Name="FullName"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank></ReportParameter>
    <ReportParameter Name="DateOfBirth"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank></ReportParameter>
    <ReportParameter Name="AppliedCourse"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank></ReportParameter>
    <ReportParameter Name="Status"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank></ReportParameter>
    <ReportParameter Name="FathersName"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank></ReportParameter>
    <ReportParameter Name="MothersName"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank></ReportParameter>
    <ReportParameter Name="ContactNo"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank></ReportParameter>
    <ReportParameter Name="EmailAddress"><DataType>String</DataType><Nullable>true</Nullable><AllowBlank>true</AllowBlank></ReportParameter>
  </ReportParameters>
  <rd:ReportUnitType>Inch</rd:ReportUnitType>
</Report>
